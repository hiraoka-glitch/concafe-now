{
  "name": "concafe-now",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev:check": "node scripts/check-env.mjs",
    "dev": "next dev -p 3000",
    "dev:with-checks": "npm-run-all -p dev wait:local",
    "wait:local": "node scripts/await-port.mjs 3000 && node scripts/smoke.mjs",
    "verify:smoke": "node scripts/smoke.mjs",
    "verify:e2e": "playwright test --reporter=list",
    "build": "next build",
    "start": "next start",
    "vercel-build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "db:setup": "prisma migrate deploy && prisma db push && prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "node -e \"if (process.env.DEMO_MODE === 'true') { console.log('Demo mode: seeding available but not auto-run'); } else { console.log('Production mode: no seeding'); }\"",
    "install:playwright": "npx playwright install --with-deps chromium",
    "test:all": "npm run verify:smoke && npm run verify:e2e"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/nodemailer": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "dompurify": "^3.2.6",
    "framer-motion": "^12.23.12",
    "jose": "^6.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.542.0",
    "nanoid": "^5.1.5",
    "next": "14.2.16",
    "next-auth": "^4.24.10",
    "nodemailer": "^6.10.1",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.1.2",
    "web-push": "^3.6.7",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^8",
    "eslint-config-next": "14.2.16",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
